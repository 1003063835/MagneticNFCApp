<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1A1A2E">

    <LinearLayout
        android:id="@+id/layoutRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E0E0E0"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sensor_ready"
            android:textColor="#8BC34A"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Magnetic Sensor Section -->
        <LinearLayout
            android:id="@+id/layoutSensorData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/magnetic_sensor"
                android:textColor="#FF9800"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/last_update_default"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:paddingBottom="12dp" />

            <!-- Axis Data Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/axis_x"
                        android:textColor="#F44336"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvMagX"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 μT"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/axis_y"
                        android:textColor="#4CAF50"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvMagY"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 μT"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/axis_z"
                        android:textColor="#2196F3"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvMagZ"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 μT"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Total Strength -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_strength"
                    android:textColor="#FFC107"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvMagTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 μT"
                    android:textColor="#FFC107"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp" />
            </LinearLayout>

            <!-- Strength Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="200"
                android:progressTint="#FF9800"
                android:progressBackgroundTint="#333344" />

            <TextView
                android:id="@+id/tvStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/strength_normal"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333344"
            android:layout_marginVertical="16dp" />

        <!-- Wheel Calibration Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wheel_calibration"
                android:textColor="#E91E63"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvCalibratedCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calibrated_count"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutPositionRow1"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:weightSum="5"
                android:layout_marginBottom="6dp">

                <TextView android:id="@+id/tvPos0" style="@style/PositionItem" android:text="0" />
                <TextView android:id="@+id/tvPos1" style="@style/PositionItem" android:text="1" />
                <TextView android:id="@+id/tvPos2" style="@style/PositionItem" android:text="2" />
                <TextView android:id="@+id/tvPos3" style="@style/PositionItem" android:text="3" />
                <TextView android:id="@+id/tvPos4" style="@style/PositionItem" android:text="4" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPositionRow2"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:weightSum="5"
                android:layout_marginBottom="12dp">

                <TextView android:id="@+id/tvPos5" style="@style/PositionItem" android:text="5" />
                <TextView android:id="@+id/tvPos6" style="@style/PositionItem" android:text="6" />
                <TextView android:id="@+id/tvPos7" style="@style/PositionItem" android:text="7" />
                <TextView android:id="@+id/tvPos8" style="@style/PositionItem" android:text="8" />
                <TextView android:id="@+id/tvPos9" style="@style/PositionItem" android:text="9" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="6dp">

                <Button
                    android:id="@+id/btnCalibrate"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/calibrate_btn"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#E91E63"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnClearCalibration"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/clear_calibration"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#607D8B" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333344"
            android:layout_marginVertical="16dp" />

        <!-- Wheel Recognition Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wheel_recognition"
                android:textColor="#00BCD4"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/tvRecognizedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recognized_no_data"
                android:textColor="#9E9E9E"
                android:textSize="16sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Divider -->

        <!-- NFC Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nfc_status"
                    android:textColor="#03A9F4"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNfcStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nfc_initializing"
                    android:textColor="#03A9F4"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnWriteAar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/write_aar_btn"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:backgroundTint="#03A9F4"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvWriteStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFC107"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#222236"
                android:padding="12dp"
                android:scrollbars="vertical"

                android:fadeScrollbars="false">

                <TextView
                    android:id="@+id/tvNfcInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/nfc_hint"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
